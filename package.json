{
  "name": "@skematica/docs",
  "version": "0.1.2",
  "description": "Local MCP server for surgical editing of Office documents (DOCX, XLSX, PPTX)",
  "license": "GPL-3.0-or-later",
  "author": "Daniel Gómez-Padilla <daniel@skemati.ca>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/skemati-ca/skematica-docs.git"
  },
  "type": "module",
  "bin": {
    "skematica-docs": "dist/index.js"
  },
  "files": [
    "dist/",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "dev": "tsx src/index.ts",
    "build": "tsc --project tsconfig.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit",
    "check": "npm run lint && npm run typecheck && npm test"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "@usejunior/docx-core": "^0.9.0",
    "fast-xml-parser": "^5.5.12",
    "jszip": "^3.10.1"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@vitest/coverage-v8": "^3.2.4",
    "eslint": "^9.0.0",
    "globals": "^16.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.6.0",
    "typescript-eslint": "^8.58.1",
    "vitest": "^3.0.0"
  }
}
